{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "validate-core-cargo-check",
			"type": "shell",
			"command": "cargo",
			"args": [
				"check",
				"--workspace",
				"-q"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "validate-core-cargo-fmt-check",
			"type": "shell",
			"command": "cargo",
			"args": [
				"fmt",
				"--all",
				"--",
				"--check"
			],
			"isBackground": false,
			"group": "build"
		}
	]
}